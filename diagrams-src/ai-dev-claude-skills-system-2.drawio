<mxfile host="app.diagrams.net">
  <diagram name="自治评审回路" id="review-loop">
    <mxGraphModel dx="1000" dy="560" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="GRP" value="自治多 Agent 评审回路:拆 bucket → 并行审 → 流式修 → 零红色收敛" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#1e293b;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="30" width="920" height="480" as="geometry"/>
        </mxCell>

        <mxCell id="D" value="变更范围" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="140" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="S" value="拆成约 20 个&#xa;窄范围 bucket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="290" y="80" width="160" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="P" value="并行派发约 20 个审查 subagent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="220" height="44" as="geometry"/>
        </mxCell>

        <mxCell id="R1" value="bucket-1 结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="170" width="130" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="R2" value="bucket-2 结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="670" y="170" width="130" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="F1" value="立即派修复 subagent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="250" width="280" height="44" as="geometry"/>
        </mxCell>

        <mxCell id="CHK" value="还有 🔴 问题?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="330" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="DONE" value="零红色 · 收敛完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="340" width="180" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="NOTE" value="分级:🔴 必须清零 · 🟡 尽量清 · 🔵 提示&#xa;审查与修复重叠执行(流水线)" style="text;html=1;align=left;fontColor=#475569;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="320" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="E1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;" edge="1" parent="1" source="D" target="S"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;" edge="1" parent="1" source="S" target="P"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;" edge="1" parent="1" source="P" target="R1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;" edge="1" parent="1" source="P" target="R2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E5" value="立即" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;fontColor=#64748b;fontSize=10;" edge="1" parent="1" source="R1" target="F1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;" edge="1" parent="1" source="R2" target="F1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;" edge="1" parent="1" source="F1" target="CHK"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E8" value="是 → 再审" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#d4a017;fontColor=#64748b;fontSize=10;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="CHK" target="P"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E9" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;" edge="1" parent="1" source="CHK" target="DONE"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
