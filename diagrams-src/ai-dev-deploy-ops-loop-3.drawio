<mxfile host="app.diagrams.net">
  <diagram name="决策矩阵" id="matrix">
    <mxGraphModel dx="900" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="820" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="自治 vs 人控: 该不该交给 AI 自治?" style="text;html=1;align=center;fontColor=#1e293b;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="420" height="26" as="geometry"/>
        </mxCell>

        <mxCell id="yaxis" value="客观验证手段" style="text;html=1;align=center;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="yup" value="有 (跑测试/编译)" style="text;html=1;align=center;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ydown" value="没有 (主观判断)" style="text;html=1;align=center;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="120" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="xaxis" value="← 可逆 ───────────── 不可逆 →" style="text;html=1;align=center;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="560" width="360" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="q1" value="全自治 ✅&#10;&#10;夜间测试 Loop&#10;Agent 修复 + 完整验证&#10;&#10;可逆 + 客观验证&#10;→ 交给机器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0f766e;fontColor=#1e293b;fontSize=12;align=center;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="220" y="100" width="200" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="q2" value="人触发 + 机器执行&#10;+ 客观验证&#10;&#10;部署流水线&#10;(人按回车, 机器跑+冒烟)&#10;&#10;可逆性低 → 留人盯" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="460" y="100" width="200" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="q3" value="只告警, 不自治&#10;&#10;定时评审 Loop&#10;数 🔴 → 飞书叫人&#10;&#10;无客观验证&#10;→ 主观判断留人" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontColor=#1e293b;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="360" width="200" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="q4" value="完全人手 + 工具兜底&#10;&#10;数据库备份 / 删数据&#10;生产排障 / 改生产配置&#10;&#10;不可逆 + 无验证&#10;→ 绝对不交机器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc2626;fontColor=#1e293b;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="460" y="360" width="200" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="cross_h" value="" style="endArrow=none;html=1;strokeColor=#cbd5e1;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="200" y="280" as="sourcePoint"/>
            <mxPoint x="680" y="280" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="cross_v" value="" style="endArrow=none;html=1;strokeColor=#cbd5e1;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="440" y="80" as="sourcePoint"/>
            <mxPoint x="440" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="footnote" value="第三轴: 失败成本 — 成本高的(备份/部署)即使满足前两条, 也留人确认" style="text;html=1;align=center;fontColor=#64748b;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="160" y="585" width="560" height="20" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
