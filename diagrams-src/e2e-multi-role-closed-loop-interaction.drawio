<mxfile host="app.diagrams.net">
  <diagram name="互动闭环" id="e2e-interaction">
    <mxGraphModel dx="900" dy="650" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t1" value="发起方 (用户2 · t2)" style="text;html=1;fontColor=#2563eb;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="30" width="200" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="业务接口" style="text;html=1;fontColor=#2563eb;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="30" width="160" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value="感知方 (用户1 · t1)" style="text;html=1;fontColor=#2563eb;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="30" width="200" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="lt1" value="" style="endArrow=none;strokeColor=#2563eb;strokeWidth=2;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="60" as="sourcePoint"/>
            <mxPoint x="160" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="lt2" value="" style="endArrow=none;strokeColor=#2563eb;strokeWidth=2;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="60" as="sourcePoint"/>
            <mxPoint x="500" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="lt3" value="" style="endArrow=none;strokeColor=#2563eb;strokeWidth=2;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="60" as="sourcePoint"/>
            <mxPoint x="840" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m1" value="POST /notifications/send  (INTERACT_LIKE)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1e293b;fontSize=11;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="100" as="sourcePoint"/>
            <mxPoint x="500" y="100" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="200 { status: SUCCESS }" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;endArrow=classic;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="140" as="sourcePoint"/>
            <mxPoint x="160" y="140" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="note1" value="⚠ 只看 200 证明不了「真落库」" style="text;html=1;fontColor=#dc2626;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="135" width="280" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m3" value="POST send (INTERACT_COMMENT)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1e293b;fontSize=11;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="200" as="sourcePoint"/>
            <mxPoint x="500" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="POST send ×3 (聚合测试)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1e293b;fontSize=11;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="250" as="sourcePoint"/>
            <mxPoint x="500" y="250" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m5" value="GET notifications/in-app" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=classic;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="340" as="sourcePoint"/>
            <mxPoint x="500" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="200 { list: [...], total: N }" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;endArrow=classic;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="380" as="sourcePoint"/>
            <mxPoint x="840" y="380" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="assert" value="数据层断言：✅ total&gt;0  ✅ 含 INTERACTION  ✅ 含@  ✅ 聚合数正确" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="430" width="400" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="cap" value="关键：发起方用 t2，感知方用 t1 — 这种「错位」正是多角色测试的精髓" style="text;html=1;align=center;fontColor=#475569;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="500" width="780" height="22" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
