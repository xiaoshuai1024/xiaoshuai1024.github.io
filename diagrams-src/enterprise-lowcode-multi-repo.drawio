<mxfile host="app.diagrams.net">
  <diagram name="鲁班多仓分工" id="lowcodeRepo">
    <mxGraphModel dx="920" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="920" pageHeight="460" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="TITLE" value="鲁班多仓分工：meta 仓 + submodule 统一治理，前端只管渲染、BFF 管认证、后端管领域" style="text;html=1;align=center;fontColor=#1e293b;fontSize=14;fontStyle=1;" vertex="1" parent="1">
