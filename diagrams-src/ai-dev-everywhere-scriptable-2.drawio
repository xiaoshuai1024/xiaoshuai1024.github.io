        <mxCell id="s1" value="执行者:人(主动跑)&#10;触发:你记得去做" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
