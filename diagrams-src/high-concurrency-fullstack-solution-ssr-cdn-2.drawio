<mxfile host="app.diagrams.net">
  <diagram name="三层降级链路" id="ssr2">
    <mxGraphModel dx="900" dy="560" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="480" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="req" value="用户请求" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="20" width="200" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="l1" value="正常：SSR 实例渲染&#10;Nginx 探活全绿，实时渲染返回" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="310" y="100" width="360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;endArrow=block;" edge="1" parent="1" source="req" target="l1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="l2" value="一级降级：Nginx 摘除故障节点&#10;单实例挂了 → 摘除，流量转健康实例&#10;用户无感" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="310" y="200" width="360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="单实例故障" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;endArrow=block;" edge="1" parent="1" source="l1" target="l2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="l3" value="二级降级：切 CSR 模式&#10;所有实例慢（&gt;3s）→ 返回空 HTML + 客户端渲染&#10;页面能开，首屏慢但内容在" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="310" y="300" width="360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="全实例异常" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;endArrow=block;" edge="1" parent="1" source="l2" target="l3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="l4" value="三级降级：静态兜底页&#10;Nginx rewrite 到 CDN 静态页&#10;「服务维护中」，绝不白屏" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="310" y="400" width="360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="CSR 也挂" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;endArrow=block;" edge="1" parent="1" source="l3" target="l4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="每一级降级都是「保内容降体验」：能渲染就渲染，渲染不了就客户端渲染，客户端也崩就给静态页。底线是不白屏。" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#1e293b;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="490" width="780" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
