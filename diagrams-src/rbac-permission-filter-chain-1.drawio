<mxfile host="app.diagrams.net">
  <diagram name="RBAC过滤器链与key对齐" id="rbacFilterChain1">
    <mxGraphModel dx="1180" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="g1" value="过滤器链 · 顺序刻死（认证 → 租户解析 → 权限校验）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;fontColor=#1e293b;verticalAlign=top;fontStyle=1;fontSize=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1100" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="f1" value="请求进入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="120" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="f2" value="① 认证&#xa;校验 token，挂当前用户" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="114" width="180" height="68" as="geometry"/>
        </mxCell>
        <mxCell id="f3" value="② 租户解析&#xa;注入 tenantId 上下文" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="114" width="180" height="68" as="geometry"/>
        </mxCell>
        <mxCell id="f4" value="③ 权限校验（枢纽）&#xa;读 @RequirePermission&#xa;按租户查权限表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;strokeWidth=2;fontColor=#1e293b;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="106" width="210" height="84" as="geometry"/>
        </mxCell>
        <mxCell id="f5" value="放行 Controller" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#14b8a6;fontColor=#134e4a;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="930" y="120" width="160" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="ffail" value="❌ 顺序错乱&#xa;租户上下文为空&#xa;→ 越权 / 全站不可用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;dashed=1;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="250" width="220" height="56" as="geometry"/>
