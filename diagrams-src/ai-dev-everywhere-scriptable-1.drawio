        <mxCell id="ME1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;dashed=1;strokeColor=#94a3b8;" edge="1" parent="1" source="P1" target="M1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ME2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;dashed=1;strokeColor=#94a3b8;" edge="1" parent="1" source="P2" target="M2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ME3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;dashed=1;strokeColor=#94a3b8;" edge="1" parent="1" source="P3" target="M3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ME4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;dashed=1;strokeColor=#94a3b8;" edge="1" parent="1" source="P4" target="M4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ME5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;dashed=1;strokeColor=#94a3b8;" edge="1" parent="1" source="P5" target="M5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="CONC" value="判断:全流程无「只能人肉做」的环节 —— 凡是重复、依赖规则、对账式的事,都能让 AI 落成脚本或 MCP" style="text;html=1;align=center;fontColor=#dc2626;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="255" width="1000" height="40" as="geometry"/>
