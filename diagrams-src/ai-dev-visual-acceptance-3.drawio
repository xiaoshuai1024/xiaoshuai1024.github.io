        <mxCell id="E_CH2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#dc2626;" edge="1" parent="1" source="CHK" target="H2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_CH3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#dc2626;" edge="1" parent="1" source="CHK" target="H3"><mxGeometry relative="1" as="geometry"/></mxCell>
