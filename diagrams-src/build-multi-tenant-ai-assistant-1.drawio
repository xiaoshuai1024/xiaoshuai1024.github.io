<mxfile host="app.diagrams.net">
  <diagram name="多租户AI助手一次对话时序" id="ai-seq">
    <mxGraphModel dx="1280" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="P_U" value="运营前端" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="40" width="120" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="PL_U" style="endArrow=none;dashed=1;html=1;strokeColor=#cbd5e1;strokeWidth=1.5;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="90" y="84" as="sourcePoint"/>
            <mxPoint x="90" y="680" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="P_C" value="聊天接口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="40" width="120" height="44" as="geometry"/>
