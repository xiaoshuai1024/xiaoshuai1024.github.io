        <mxCell id="EO23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="O2" target="O3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="EO34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="O3" target="O4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="EO45" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;dashed=1;strokeColor=#94a3b8;" edge="1" parent="1" source="O4" target="O5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="CONC" value="互补不互斥: 新功能保实现完整 + 样式对, 老功能保兼容 + 扫历史遗留 —— 一个版本两边一起跑, 380 页才覆盖得过来" style="text;html=1;align=center;fontColor=#dc2626;fontSize=11;fontStyle=1;" vertex="1" parent="1">
