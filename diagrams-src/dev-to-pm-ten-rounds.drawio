        <mxCell id="L5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;startArrow=classic;" edge="1" parent="1" source="V5" target="CORE"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="L6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;startArrow=classic;" edge="1" parent="1" source="V6" target="CORE"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="L7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;startArrow=classic;" edge="1" parent="1" source="V7" target="CORE"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="L8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;startArrow=classic;" edge="1" parent="1" source="V8" target="CORE"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="L9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;startArrow=classic;" edge="1" parent="1" source="V9" target="CORE"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="L10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;startArrow=classic;" edge="1" parent="1" source="V10" target="CORE"><mxGeometry relative="1" as="geometry"/></mxCell>

