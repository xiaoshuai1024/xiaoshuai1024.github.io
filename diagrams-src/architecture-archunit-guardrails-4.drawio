          <mxGeometry x="60" y="180" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="AI" value="AI 生成代码" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="240" y="180" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="Q" value="AI 在乎&#xa;架构吗?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="170" width="130" height="70" as="geometry"/>
