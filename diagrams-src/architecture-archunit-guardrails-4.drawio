        <mxCell id="E1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;" edge="1" parent="1" source="REQ" target="AI">
          <mxGeometry relative="1" as="geometry"/>
