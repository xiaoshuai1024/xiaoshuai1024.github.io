        <mxCell id="G" value="架构守护拦下&#xa;提交时 CI 挂掉，根本进不来" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
