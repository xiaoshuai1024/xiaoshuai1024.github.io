<mxfile host="app.diagrams.net">
  <diagram name="多租户行级隔离三层兜底" id="mtIso1">
    <mxGraphModel dx="1180" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="r1" value="HTTP 请求&#xa;Header: X-Tenant-Id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f1" value="TenantFilter&#xa;解析 X-Tenant-Id&#xa;塞入请求级上下文" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;strokeWidth=2;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="55" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="c1" value="TenantContext&#xa;(ThreadLocal)&#xa;请求全程可取" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="60" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="业务 SQL&#xa;必须带 tenant_id 条件&#xa;(含每个 JOIN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#14b8a6;fontColor=#134e4a;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="60" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="ed1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;strokeWidth=1.5;fontColor=#475569;fontSize=10;endArrow=block;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="r1" target="f1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ed2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;strokeWidth=1.5;fontColor=#475569;fontSize=10;endArrow=block;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="f1" target="c1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ed3" value="漏带了?" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;strokeWidth=1.5;fontColor=#475569;fontSize=10;endArrow=block;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="c1" target="s1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="grp" value="三层兜底:假设迟早有人会漏,提前把网织好" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;fontColor=#1e293b;verticalAlign=top;fontStyle=1;fontSize=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="960" height="320" as="geometry"/>
        </mxCell>

        <mxCell id="g1" value="① SQL 审查清单&#xa;每个 JOIN 必带&#xa;a.tenant_id = b.tenant_id&#xa;评审逐条过,不凭感觉" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="300" width="220" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="g2" value="② 契约扫描&#xa;扫 MyBatis / 原生 SQL&#xa;找 JOIN 验 tenant_id&#xa;漏带的 PR 直接标红" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="350" y="300" width="220" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="g3" value="③ 评审回路(枢纽)&#xa;扫描器喂疑点给评审 Agent&#xa;Agent 逐条判漏带/豁免/存疑&#xa;人对存疑做最终拍板" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;strokeWidth=2;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="620" y="295" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="ed4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;strokeWidth=1.5;fontColor=#475569;fontSize=10;endArrow=block;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="g1" target="g2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ed5" value="疑点" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;strokeWidth=1.5;fontColor=#475569;fontSize=10;endArrow=block;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="g2" target="g3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="res" value="想漏一个 tenant_id,得同时骗过三关" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#14b8a6;fontColor=#134e4a;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="350" y="470" width="380" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="ed6" value="层层兜" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;strokeWidth=1.5;fontColor=#475569;fontSize=10;endArrow=block;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="g3" target="res">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ed7" value="假设会漏" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#94a3b8;strokeWidth=1.5;fontColor=#94a3b8;fontSize=10;endArrow=block;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="s1" target="g3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
