<mxfile host="app.diagrams.net">
  <diagram name="deploy" id="deploy">
    <mxGraphModel dx="1180" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="CD 阶段：/deploy 六步构建部署 + /prod-testing 三层冒烟" style="text;html=1;align=center;fontColor=#1e293b;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="20" width="700" height="28" as="geometry"/>
