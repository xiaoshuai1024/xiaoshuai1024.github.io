        </mxCell>
        <mxCell id="step5" value="Step 5&#10;systemctl restart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="100" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step5d" value="pkill -f '[b]ackend.jar'&#10;方括号绕开自杀匹配" style="text;html=1;align=center;fontColor=#d97706;fontSize=10;fontStyle=2;" vertex="1" parent="1">
