<mxfile host="app.diagrams.net">
  <diagram name="研发做产品的六个错" id="six-mistakes">
    <mxGraphModel dx="1100" dy="660" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="TITLE" value="研发做产品,稳定地掉进这 6 个坑" style="text;html=1;align=center;fontStyle=1;fontSize=14;fontColor=#1e293b;" vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="420" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="ROOT" value="共同的根子:&#xa;把产品当技术题,但产品是判断题" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="470" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="M1" value="错一 把功能当价值&#xa;「我做完了」≠「有人用」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="250" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="M2" value="错二 没有整体观&#xa;只看自己这摊,接缝处漏水" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="90" width="250" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="M3" value="错三 对商业模式不敏感&#xa;做了一堆「正确但没用」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="90" width="250" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="M4" value="错四 只接需求字面意思&#xa;最普遍的浪费" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="250" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="M5" value="错五 从自身出发开发&#xa;研发是最不像用户的人" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="240" width="250" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="M6" value="错六 不验证假设&#xa;没埋点 = 没上线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="240" width="250" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="F1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1" source="M1" target="ROOT"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="F2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1" source="M2" target="ROOT"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="F3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1" source="M3" target="ROOT"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="F4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1" source="M4" target="ROOT"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="F5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1" source="M5" target="ROOT"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="F6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1" source="M6" target="ROOT"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
