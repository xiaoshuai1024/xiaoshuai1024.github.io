        <mxCell id="s6" value="6. 规则库 = 事故档案&#10;新人读规则库 = 继承经验&#10;不用重新踩坑" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bfdbfe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
