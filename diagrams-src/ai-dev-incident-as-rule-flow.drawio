        <mxCell id="s5" value="5. 自动生效&#10;下次同类操作被机器拦&#10;不靠人记得" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#0f766e;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
