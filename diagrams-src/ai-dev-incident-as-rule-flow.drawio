        <mxCell id="key" value="关键:复盘不落规则 = 没复盘 · 每起事故必须产出至少一条固化规则&#10;规则库定期清理过时规则,精不要多" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=11;dashed=1;" vertex="1" parent="1">
