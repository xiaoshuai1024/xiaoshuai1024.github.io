<mxfile host="app.diagrams.net"><diagram name="保障层" id="layers1"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" page="1" pageWidth="1100" pageHeight="480" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="AI 保障的五层骨架" style="text;html=1;align=center;fontColor=#1e293b;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="400" y="20" width="300" height="28" as="geometry"/></mxCell><mxCell id="l1" value="① 评审回路&#10;独立 Agent 分桶审查 + 收敛循环&#10;解决：写代码和审代码盲区重叠" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="30" y="70" width="310" height="80" as="geometry"/></mxCell><mxCell id="l2" value="② 契约闸&#10;pre-commit 四层跨层扫描&#10;解决：改了一层忘了同步另一层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="370" y="70" width="310" height="80" as="geometry"/></mxCell><mxCell id="l3" value="③ 测试门禁&#10;UT/IT/E2E + verify 强制&#10;解决：编译过但行为被静默删除" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="710" y="70" width="310" height="80" as="geometry"/></mxCell><mxCell id="l4" value="④ 规范固化&#10;规则前置 + 技能 + 危险命令 hook&#10;解决：AI 不知道项目红线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="200" y="190" width="310" height="80" as="geometry"/></mxCell><mxCell id="l5" value="⑤ ArchUnit 架构守护&#10;架构规则写成测试 + freeze 基线&#10;解决：AI 架构越界(数据层直连SQL/定时任务调TenantContext)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="540" y="190" width="360" height="80" as="geometry"/></mxCell><mxCell id="cap" value="每层兜住其它层的盲区 — 少一层 AI 就多一个逃逸口子" style="text;html=1;align=center;fontColor=#475569;fontSize=11;" vertex="1" parent="1"><mxGeometry x="250" y="300" width="600" height="22" as="geometry"/></mxCell><mxCell id="principle" value="设计原则：① 分层不靠单道    ② 机器执行不靠人记    ③ 可验证不是黑话" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="150" y="350" width="800" height="40" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
