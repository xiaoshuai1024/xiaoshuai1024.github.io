<mxfile host="app.diagrams.net"><diagram name="衔接" id="flow1"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" page="1" pageWidth="1100" pageHeight="360" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="保障层与 AI 工作流的三个衔接时机" style="text;html=1;align=center;fontColor=#1e293b;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="350" y="20" width="400" height="28" as="geometry"/></mxCell><mxCell id="t1" value="写之前：规则前置&#10;&#10;Agent 启动加载规则文件&#10;AI 还没动笔就知道红线&#10;成本：零 (预防)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="290" height="110" as="geometry"/></mxCell><mxCell id="t2" value="写之中：实时校验&#10;&#10;IDE hook 跑轻量检查&#10;违规当场提示趁热纠正&#10;成本：秒级 (低成本)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="390" y="80" width="290" height="110" as="geometry"/></mxCell><mxCell id="t3" value="提交前：全量门禁&#10;&#10;契约闸 + 测试 + ArchUnit&#10;任何一道红打回重改&#10;成本：分钟级 (最可靠)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="740" y="80" width="290" height="110" as="geometry"/></mxCell><mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;" edge="1" parent="1" source="t1" target="t2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;" edge="1" parent="1" source="t2" target="t3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="loop" value="事故 → 新规则 → 写进 ArchUnit/hook → 下次同类错误被拦    保障层是被事故喂出来的活体系" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="150" y="230" width="800" height="44" as="geometry"/></mxCell><mxCell id="el" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#94a3b8;fontSize=11;dashed=1;" edge="1" parent="1" source="t3" target="loop"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
