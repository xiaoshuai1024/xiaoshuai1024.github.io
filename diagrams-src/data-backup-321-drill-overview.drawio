<mxfile host="app.diagrams.net">
  <diagram name="321备份总览" id="backup-overview">
    <mxGraphModel dx="900" dy="650" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="3-2-1 原则：3 份副本 · 2 种介质 · 1 份异地" style="text;html=1;align=center;fontColor=#1e293b;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="540" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="prod" value="生产可用区 A&#10;&#10;MySQL 主库&#10;七牛 OSS 主 bucket&#10;.env.prod 秘钥" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="220" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="dr" value="灾备可用区 B（异地/异云）&#10;&#10;MySQL 只读从库 (binlog 复制)&#10;七牛 OSS 备用 bucket (跨区域镜像)&#10;跨云 OSS 冷备 (阿里云/腾讯云)&#10;age 加密秘钥副本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="760" y="80" width="260" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="e1" value="① binlog 持续复制 (RPO ≤ 5min)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="prod" target="dr">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="② 每日全量 mysqldump → gzip+SHA256 → 跨云" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;exitX=1;exitY=0.55;exitDx=0;exitDy=0;entryX=0;entryY=0.6;entryDx=0;entryDy=0;" edge="1" parent="1" source="prod" target="dr">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="③ OSS 跨云增量同步 (rclone --checksum)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;exitX=1;exitY=0.8;exitDx=0;exitDy=0;entryX=0;entryY=0.85;entryDx=0;entryDy=0;" edge="1" parent="1" source="prod" target="dr">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="layers" value="备份三层体系&#10;&#10;第一层  binlog 热复制（RPO 主力）&#10;第二层  每日全量 dump（干净快照兜底）&#10;第三层  manifest 日报（可观测性，防静默失败）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontColor=#1e293b;fontSize=12;align=left;spacingLeft=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="360" y="260" width="380" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ret" value="保留策略：日备×7 / 周备×4 / 月备×12，每份 3 副本（本地磁盘 + 跨云 OSS 两区域）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="260" y="400" width="580" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="drill" value="每月恢复演练（5 步 SOP）→  失败即阻断发布" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="330" y="470" width="440" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="ed1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#94a3b8;fontSize=11;dashed=1;" edge="1" parent="1" source="ret" target="drill">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
