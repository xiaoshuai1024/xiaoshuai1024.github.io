        <mxCell id="e2" value="运营操作" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=10;" edge="1" parent="1" source="user" target="engine">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="/api proxy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=10;" edge="1" parent="1" source="engine" target="bff">
          <mxGeometry relative="1" as="geometry"/>
