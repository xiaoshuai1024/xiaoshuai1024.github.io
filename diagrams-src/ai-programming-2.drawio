        <mxCell id="Q" value="要干的活是什么？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="60" width="180" height="80" as="geometry"/>
        </mxCell>
