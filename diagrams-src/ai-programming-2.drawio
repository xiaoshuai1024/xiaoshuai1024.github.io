          <mxGeometry x="260" y="200" width="200" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="A_OC" value="OpenCode&#10;开源命令行场景 /&#10;需要本地可控时切" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="200" width="200" height="90" as="geometry"/>
