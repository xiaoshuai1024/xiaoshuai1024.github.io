        <mxCell id="E1" value="端到端 / 重活" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#475569;fontSize=10;" edge="1" parent="1" source="Q" target="A_CC"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E2" value="编辑器内中改动" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#475569;fontSize=10;" edge="1" parent="1" source="Q" target="A_CUR"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E3" value="本地可控" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#475569;fontSize=10;" edge="1" parent="1" source="Q" target="A_OC"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E4" value="行内补全" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#475569;fontSize=10;" edge="1" parent="1" source="Q" target="A_CX"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="NOTE" value="铁律：核心业务逻辑 / 架构设计 不外包给 AI —— 它没有你的业务上下文，&quot;对&quot;只是通用意义上的对" style="text;html=1;align=center;fontColor=#dc2626;fontSize=11;fontStyle=1;" vertex="1" parent="1">
