        <mxCell id="A_CX" value="Codex / Copilot&#10;行内补全 / 样板联想 /&#10;注释驱动小段生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="200" width="160" height="90" as="geometry"/>
