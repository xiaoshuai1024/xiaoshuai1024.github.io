<mxfile host="app.diagrams.net">
  <diagram name="工具层类关系" id="bridge-cls">
    <mxGraphModel dx="1200" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="GRP_SELF" value="自研工具层（业务只依赖这一层，看不到任何 Spring AI 类型）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#1e293b;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="30" width="850" height="720" as="geometry"/>
        </mxCell>

        <mxCell id="GRP_SPRING" value="桥接层 + Spring AI（换框架只动这里）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0fdfa;strokeColor=#5eead4;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#134e4a;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="30" width="270" height="720" as="geometry"/>
        </mxCell>

        <mxCell id="C_AIT" value="&lt;i&gt;&amp;lt;&amp;lt;annotation&amp;gt;&amp;gt;&lt;/i&gt;&#xa;@AiTool&#xa;—&#xa;+ name : String&#xa;+ description : String&#xa;+ requiresConfirmation : boolean&#xa;+ module : String" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="230" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="C_TH" value="&lt;i&gt;&amp;lt;&amp;lt;interface&amp;gt;&amp;gt;&lt;/i&gt;&#xa;ToolHandler&#xa;—&#xa;+ execute(args : Map,&#xa;       ctx : ToolContext)&#xa;       : ToolResult" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="70" width="240" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="C_CTX" value="&lt;i&gt;&amp;lt;&amp;lt;record&amp;gt;&amp;gt;&lt;/i&gt;&#xa;ToolContext&#xa;—&#xa;+ tenantId : String&#xa;+ userId : String&#xa;+ conversationId : String" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="70" width="220" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="C_RES" value="&lt;i&gt;&amp;lt;&amp;lt;record&amp;gt;&amp;gt;&lt;/i&gt;&#xa;ToolResult&#xa;—&#xa;+ ok : boolean&#xa;+ data : Map&#xa;+ errorMessage : String&#xa;—&#xa;+ success(data) : ToolResult&#xa;+ error(msg) : ToolResult" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="290" width="240" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="C_REG" value="ToolRegistry&#xa;—&#xa;+ handlers : Map&lt;String, ToolHandler&gt;&#xa;—&#xa;+ getAllToolDefinitions() : List&#xa;+ get(name) : ToolHandler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="520" width="230" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="C_ORD" value="OrderQueryTool&#xa;（业务工具示例）&#xa;—&#xa;+ execute(args, ctx)&#xa;  : ctx.tenantId() 做租户隔离" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="520" width="240" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="C_BRIDGE" value="AiToolBridgeConfig&#xa;—&#xa;+ bridge()&#xa;       : FunctionToolCallback[]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#14b8a6;fontColor=#134e4a;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="920" y="70" width="230" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="C_FTC" value="&lt;i&gt;&amp;lt;&amp;lt;Spring AI&amp;gt;&amp;gt;&lt;/i&gt;&#xa;FunctionToolCallback&#xa;—&#xa;+ builder(name, fn)&#xa;+ description(...)&#xa;+ inputType(Map.class)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#14b8a6;fontColor=#134e4a;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="920" y="230" width="230" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="R_TH_CTX" value="入参" style="endArrow=open;dashed=1;html=1;strokeColor=#475569;strokeWidth=1.5;fontSize=10;fontColor=#475569;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="C_TH" target="C_CTX">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="R_TH_RES" value="返回" style="endArrow=open;dashed=1;html=1;strokeColor=#475569;strokeWidth=1.5;fontSize=10;fontColor=#475569;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="C_TH" target="C_RES">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="R_ORD_TH" value="implements" style="endArrow=block;html=1;strokeColor=#475569;strokeWidth=1.5;fontSize=10;fontColor=#475569;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="C_ORD" target="C_TH">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="460" y="495"/>
              <mxPoint x="460" y="495"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="R_ORD_AIT" value="@AiTool 标注" style="endArrow=open;dashed=1;html=1;strokeColor=#475569;strokeWidth=1.5;fontSize=10;fontColor=#475569;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.8;entryDx=0;entryDy=0;" edge="1" parent="1" source="C_ORD" target="C_AIT">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="165" y="595"/>
              <mxPoint x="165" y="200"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="R_REG_TH" value="收集所有 ToolHandler bean" style="endArrow=block;startArrow=diamondThin;startFill=0;html=1;strokeColor=#475569;strokeWidth=1.5;fontSize=10;fontColor=#475569;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.65;entryDx=0;entryDy=0;" edge="1" parent="1" source="C_REG" target="C_TH">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="565"/>
              <mxPoint x="320" y="160"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="R_BRIDGE_REG" value="取定义" style="endArrow=open;dashed=1;html=1;strokeColor=#14b8a6;strokeWidth=1.5;fontSize=10;fontColor=#134e4a;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.8;entryDx=0;entryDy=0;" edge="1" parent="1" source="C_BRIDGE" target="C_REG">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="920" y="230"/>
              <mxPoint x="920" y="640"/>
              <mxPoint x="280" y="640"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="R_BRIDGE_FTC" value="适配" style="endArrow=block;html=1;strokeColor=#14b8a6;strokeWidth=1.5;fontSize=10;fontColor=#134e4a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="C_BRIDGE" target="C_FTC">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="LEGEND" value="图例：白底蓝边 = 自研类型 / 概念；蓝填充 = 该层核心抽象；青绿色 = 桥接 + Spring AI 侧。虚线 = 依赖 / 标注关系，实线箭头 = 实现，菱形 = 聚合。换 AI 框架时只改青绿色区域。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=10;fontColor=#475569;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="920" y="640" width="230" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
