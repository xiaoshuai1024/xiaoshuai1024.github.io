<mxfile host="app.diagrams.net">
  <diagram name="三种学习模式" id="pk2">
    <mxGraphModel dx="800" dy="480" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="420" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="kb" value="同一个知识库&#10;按主题分库 + metadata filter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="模式一：查资料&#10;「这个知识点是什么」&#10;prompt: 学习助手,看资料回答" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="模式二：模拟面试&#10;「考考我」&#10;prompt: 面试官,抽题→作答→点评" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="330" y="130" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="m3" value="模式三：知识连接&#10;「A 和 B 有什么关系」&#10;prompt: 架构教练,跨库检索对比" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="620" y="130" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;endArrow=block;" edge="1" parent="1" source="kb" target="m1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;endArrow=block;" edge="1" parent="1" source="kb" target="m2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;endArrow=block;" edge="1" parent="1" source="kb" target="m3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1l" value="换 prompt" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#64748b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="90" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="架构不变,只换 system prompt,就能从「查资料」切到「被考」再切到「串联对比」。一个库三种用法。" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#1e293b;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="820" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="note2" value="主动回忆（模式二）比被动重读（模式一）有效十倍,这是学习科学反复验证的。" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#0f766e;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="295" width="820" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
