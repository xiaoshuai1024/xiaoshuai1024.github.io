<mxfile host="app.diagrams.net">
  <diagram name="三层阶梯" id="ladder">
    <mxGraphModel dx="800" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="780" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- 第一层:H5 -->
        <mxCell id="l1" value="第一层 · H5 Playwright" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="520" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="l1n" value="标准 DOM · headed 可视化 · 调试快&#10;过滤 90% 显性问题:事件没绑、路由 404、校验失效" style="text;html=1;align=left;fontColor=#475569;fontSize=12;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="52" y="78" width="496" height="56" as="geometry"/>
        </mxCell>
