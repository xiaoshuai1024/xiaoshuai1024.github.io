        <!-- 禁止跳层标注 -->
        <mxCell id="ban" value="禁止跳层&#10;automator 不是首选" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#dc2626;fontColor=#dc2626;fontSize=12;fontStyle=1;dashed=1;" vertex="1" parent="1">
