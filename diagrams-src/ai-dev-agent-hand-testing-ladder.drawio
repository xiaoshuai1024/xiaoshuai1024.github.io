        <mxCell id="l2" value="第二层 · 运营后台 E2E" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="520" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="l2n" value="Element Plus · 管理和配置侧旅程&#10;验证「后台改配置 → C 端生效」跨端联动" style="text;html=1;align=left;fontColor=#475569;fontSize=12;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="112" y="238" width="496" height="56" as="geometry"/>
        </mxCell>
        <!-- 第三层:小程序 -->
        <mxCell id="l3" value="第三层 · 微信小程序 automator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="160" y="360" width="520" height="110" as="geometry"/>
