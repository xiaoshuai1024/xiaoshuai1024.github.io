<mxfile host="app.diagrams.net">
  <diagram name="单向数据流" id="lb2">
    <mxGraphModel dx="900" dy="560" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1080" pageHeight="480" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="host" value="宿主（编辑器 / 业务层）&#10;持有可变 schema" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=13;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="60" width="240" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="h1" value="schema 树" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="h2" value="formState 字典" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="h3" value="事件处理 / 改 schema" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="210" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="engine" value="渲染引擎（dumb）&#10;只渲染 + 发事件&#10;不持状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=13;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="240" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="e1" value="给 schema，渲染画布" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1" source="host" target="engine">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="用户操作 → 发事件&#10;node:create / node:move ..." style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;endArrow=block;dashed=1;" edge="1" parent="1" source="engine" target="host">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="comp" value="Vue 组件库（共用）&#10;props + slot 驱动&#10;不知自己被谁渲染" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0f766e;fontColor=#1e293b;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="220" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="registry 查组件渲染" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;endArrow=block;" edge="1" parent="1" source="engine" target="comp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="关键：引擎手里没有「可变的 schema」，只有「当前 props 那一份」。改 schema 是宿主的事，引擎只负责反映。" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#1e293b;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="310" width="880" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="note2" value="因为单向 + 无状态，引擎可以配 Vue 宿主、React 宿主、甚至后端渲染宿主。" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#0f766e;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="355" width="880" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
