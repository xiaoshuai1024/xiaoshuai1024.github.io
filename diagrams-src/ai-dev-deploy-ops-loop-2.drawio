<mxfile host="app.diagrams.net">
  <diagram name="一天时间轴" id="timeline">
    <mxGraphModel dx="1100" dy="560" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="480" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="一天里在跑的三个 Loop" style="text;html=1;align=center;fontColor=#1e293b;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="300" height="26" as="geometry"/>
        </mxCell>

        <mxCell id="axis" value="" style="endArrow=classic;html=1;strokeColor=#1e293b;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="60" y="240" as="sourcePoint"/>
            <mxPoint x="1040" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="t0000" value="00:00" style="text;html=1;align=center;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="250" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="t0300" value="03:00" style="text;html=1;align=center;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="250" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="t09" value="09:00 上班" style="text;html=1;align=center;fontColor=#64748b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="830" y="250" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="tnext" value="次日 00:00" style="text;html=1;align=center;fontColor=#94a3b8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="970" y="250" width="80" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="dot1" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2563eb;strokeColor=#2563eb;" vertex="1" parent="1">
          <mxGeometry x="143" y="233" width="14" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="dot2" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0f766e;strokeColor=#0f766e;" vertex="1" parent="1">
          <mxGeometry x="523" y="233" width="14" height="14" as="geometry"/>
        </mxCell>

        <mxCell id="nightly_box" value="夜间测试 Loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#2563eb;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="90" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="nightly_detail" value="同步 dev → 8 步测试&#10;失败 → claude 修 → 验证 → MR&#10;耗时 40–60 min · 命中率 ~60%&#10;&#10;⚠️ 可逆 + 客观验证 → 全自治" style="text;html=1;align=center;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="135" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="line1" value="" style="endArrow=none;html=1;strokeColor=#2563eb;dashed=1;" edge="1" parent="1" source="nightly_box" target="dot1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="review_box" value="定时评审 Loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0f766e;fontColor=#0f766e;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="430" y="90" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="review_detail" value="扫 feature 分支相对 dev 改动&#10;数 🔴 阻断 → 飞书告警&#10;只读, 不改代码&#10;&#10;⚠️ 主观判断 → 只告警不自治" style="text;html=1;align=center;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="410" y="135" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="line2" value="" style="endArrow=none;html=1;strokeColor=#0f766e;dashed=1;" edge="1" parent="1" source="review_box" target="dot2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="backup_box" value="数据库备份 Loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0f766e;fontColor=#0f766e;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="690" y="90" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="backup_detail" value="从只读从库 mysqldump&#10;gzip + SHA256 → 跨云 OSS&#10;3-2-1: 日7+周4+月12&#10;&#10;⚠️ 不可逆 → 人确认, 失败必告警" style="text;html=1;align=center;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="135" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="line3" value="" style="endArrow=none;html=1;strokeColor=#0f766e;dashed=1;" edge="1" parent="1" source="backup_box" target="dot2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="human" value="白天: 人看昨晚的 Loop 结果 → review MR / 处理告警 → 手动发版(命令化骨架)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontColor=#475569;fontSize=11;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="300" width="700" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="principle" value="机器兜夜间例行 + 人处理例外 — 两者互补, 不是替代" style="text;html=1;align=center;fontColor=#64748b;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="320" y="355" width="460" height="24" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
