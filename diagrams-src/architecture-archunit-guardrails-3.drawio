        <mxCell id="BAD3" value="❌ 循环依赖（no-circular）" style="text;html=1;align=left;fontColor=#dc2626;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="190" width="220" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="E_PC" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;" edge="1" parent="1" source="P" target="C">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="E_PS" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;" edge="1" parent="1" source="P" target="S">
