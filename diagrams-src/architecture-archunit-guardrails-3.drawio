        <mxCell id="E_CCO" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;" edge="1" parent="1" source="C" target="CO">
          <mxGeometry relative="1" as="geometry"/>
