<mxfile host="app.diagrams.net">
  <diagram name="夜间全量测试+自动修复" id="nightly">
    <mxGraphModel dx="1200" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1140" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="TRIGGER" value="定时触发 (默认每天 00:00, 可 --time)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;strokeWidth=2;fontStyle=1;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="380" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="P0" value="Phase 0 · 预检&#10;平台检测 + Node 初始化 + 获取运行锁&#10;save_state: 记录每仓库当前分支" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="76" width="380" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="P1" value="Phase 1 · 工作区准备&#10;未提交改动 → auto-commit (wip: nightly checkpoint)&#10;每仓库 checkout dev → pull origin/dev" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="152" width="380" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="P2_GRP" value="Phase 2 · 全量测试 (8 步, fail-fast)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#1e293b;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="228" width="1060" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="S13" value="①③ 后端单测 + 前端单测&#10;(并行)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="262" width="180" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="S2" value="② 后端集成测" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="262" width="140" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="S4" value="④ 运营后台单测" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="262" width="140" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="S5" value="⑤ 启动后端 :8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="262" width="140" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="S6" value="⑥ 运营 E2E" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="262" width="120" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="S7" value="⑦ 前端 H5 E2E" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="262" width="120" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="S8" value="⑧ 小程序编译验证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="326" width="200" height="0" as="geometry"/>
        </mxCell>

        <mxCell id="DECISION" value="测试结果?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="510" y="356" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="PASS" value="全过 → 飞书 [PASS]&#10;直接进 Phase 4 恢复" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#16a34a;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="362" width="200" height="48" as="geometry"/>
        </mxCell>

        <mxCell id="P3_GRP" value="Phase 3 · 失败处理 (仅代码失败触发)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#dc2626;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#1e293b;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="1060" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="ENV_FAIL" value="环境失败&#10;(后端启不来/DB 不可达)&#10;→ 飞书告警, 跳过修复" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc2626;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="476" width="220" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="AGENT_FIX" value="3a · Agent 分析日志&#10;切 fix 分支 → 改代码 → push&#10;(不提 MR, 交给脚本验证)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="476" width="240" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="REVERIFY" value="3b · 脚本切 fix 分支&#10;重跑【完整 8 步测试】防回归" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="476" width="240" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="REVERIFY_DEC" value="回归通过?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="476" width="120" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="MR_OK" value="3c · 创建 MR 到 dev&#10;(不合并) → 飞书「已修复+MR」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#16a34a;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="260" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="MR_FAIL" value="删 fix 分支&#10;→ 飞书「修复未通过验证, 需人工」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc2626;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="560" width="280" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="NO_ROOT" value="Agent 无法定根因&#10;→ 输出分析, 不强改, 飞书通知" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc2626;fontColor=#1e293b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="560" width="260" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="P4" value="Phase 4 · 恢复 (always, 含 trap 兜底)&#10;restore_state: 切回每仓库原始分支 (含 fix 分支清理)&#10;stop_backend · 释放锁" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="680" width="380" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="DONE" value="完成 · 开发者工作区无损还原" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;strokeWidth=2;fontStyle=1;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="752" width="380" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="E_T_P0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="TRIGGER" target="P0"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_P0_P1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="P0" target="P1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_P1_P2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="P1" target="P2_GRP"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_P2_DEC" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="P2_GRP" target="DECISION"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_DEC_PASS" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#16a34a;" edge="1" parent="1" source="DECISION" target="PASS"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_DEC_P3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#dc2626;" edge="1" parent="1" source="DECISION" target="P3_GRP"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_FIX_REVER" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;" edge="1" parent="1" source="AGENT_FIX" target="REVERIFY"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_REVER_DEC" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;" edge="1" parent="1" source="REVERIFY" target="REVERIFY_DEC"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_DEC_MROK" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#16a34a;" edge="1" parent="1" source="REVERIFY_DEC" target="MR_OK"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_DEC_MRFAIL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#dc2626;" edge="1" parent="1" source="REVERIFY_DEC" target="MR_FAIL"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_PASS_P4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1" source="PASS" target="P4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_P3_P4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1" source="P3_GRP" target="P4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="E_P4_DONE" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="P4" target="DONE"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
