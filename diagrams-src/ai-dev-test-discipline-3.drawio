        <mxCell id="r2" value="挡住：测试数据混进生产租户" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontColor=#64748b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="170" width="300" height="30" as="geometry"/>
