<mxfile host="app.diagrams.net">
  <diagram name="代开生命周期时序" id="lifecycle">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 五个角色 lifeline 顶 -->
        <mxCell id="h_op" value="运营/平台" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="120" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="h_be" value="SaaS 后端" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="40" width="120" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="h_wx" value="微信开放平台" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="40" width="140" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="h_audit" value="微信审核" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="40" width="120" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="h_mini" value="租户小程序" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="40" width="120" height="36" as="geometry"/>
        </mxCell>

        <!-- lifelines -->
        <mxCell id="ll_op" value="" style="endArrow=none;html=1;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="120" y="76" as="sourcePoint"/>
            <mxPoint x="120" y="720" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_be" value="" style="endArrow=none;html=1;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="76" as="sourcePoint"/>
            <mxPoint x="330" y="720" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_wx" value="" style="endArrow=none;html=1;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="570" y="76" as="sourcePoint"/>
            <mxPoint x="570" y="720" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_audit" value="" style="endArrow=none;html=1;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="790" y="76" as="sourcePoint"/>
            <mxPoint x="790" y="720" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_mini" value="" style="endArrow=none;html=1;strokeColor=#94a3b8;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1000" y="76" as="sourcePoint"/>
            <mxPoint x="1000" y="720" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 步骤 1: 授权 -->
        <mxCell id="s1" value="1. 生成预授权 URL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1" source="ll_op" target="ll_be">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="120" y="110" as="sourcePoint"/>
            <mxPoint x="330" y="110" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s2" value="2. 创建预授权码 / 拉授权 URL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="140" as="sourcePoint"/>
            <mxPoint x="570" y="140" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s3" value="3. 租户扫码授权平台代管" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="120" y="175" as="sourcePoint"/>
            <mxPoint x="570" y="175" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 步骤 2: 代注册(可选) -->
        <mxCell id="s4" value="4. (可选)代注册:企业资料 → 注册小程序" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;fontSize=11;endArrow=block;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="220" as="sourcePoint"/>
            <mxPoint x="570" y="220" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 步骤 3: commit -->
        <mxCell id="s5" value="5. /wxa/commit  提交模板 + ext_json(tenantId)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="270" as="sourcePoint"/>
            <mxPoint x="570" y="270" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s5note" value="版本号自增&#10;1.0.3 → 1.0.4" style="text;html=1;fontColor=#64748b;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="600" y="255" width="110" height="40" as="geometry"/>
        </mxCell>

        <!-- 步骤 4: 提审 -->
        <mxCell id="s6" value="6. /wxa/submit_audit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="335" as="sourcePoint"/>
            <mxPoint x="570" y="335" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s7" value="7. 进审核队列" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="570" y="365" as="sourcePoint"/>
            <mxPoint x="790" y="365" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s8" value="8. 审核通过 / 驳回" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="790" y="405" as="sourcePoint"/>
            <mxPoint x="330" y="405" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 步骤 5: 发布 -->
        <mxCell id="s9" value="9. /wxa/release 发布" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="450" as="sourcePoint"/>
            <mxPoint x="570" y="450" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s10" value="10. 上线,租户可用" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=11;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="570" y="490" as="sourcePoint"/>
            <mxPoint x="1000" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 回滚分支 -->
        <mxCell id="rb1" value="回滚:查历史模板 → 重新 commit + 发布" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#dc2626;fontSize=11;endArrow=block;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="565" as="sourcePoint"/>
            <mxPoint x="1000" y="565" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="rb_note" value="出事故时走这条&#10;按版本号回退" style="text;html=1;fontColor=#dc2626;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="600" y="580" width="120" height="36" as="geometry"/>
        </mxCell>

        <!-- 体验版分支 -->
        <mxCell id="exp1" value="体验版:set体验版 + 拉二维码" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;fontSize=11;endArrow=block;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="640" as="sourcePoint"/>
            <mxPoint x="1000" y="640" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 图例 -->
        <mxCell id="legend_title" value="图例" style="text;html=1;fontColor=#1e293b;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="690" width="50" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg_main" value="主流程" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2563eb;fontSize=10;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="120" y="700" as="sourcePoint"/>
            <mxPoint x="170" y="700" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg_opt" value="可选 / 体验版" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;fontSize=10;endArrow=block;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="230" y="700" as="sourcePoint"/>
            <mxPoint x="280" y="700" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg_rb" value="回滚" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#dc2626;fontSize=10;endArrow=block;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="700" as="sourcePoint"/>
            <mxPoint x="410" y="700" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
