<mxfile host="app.diagrams.net">
  <diagram name="五层自愈架构总览" id="overview">
    <mxGraphModel dx="1169" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="820" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 标题 -->
        <mxCell id="title" value="线上智能监控与缺陷自愈 · 五层架构" style="text;html=1;align=center;fontSize=16;fontStyle=1;fontColor=#1e293b;" vertex="1" parent="1">
          <mxGeometry x="280" y="14" width="600" height="30" as="geometry"/>
        </mxCell>

        <!-- 第一层：指标定义 -->
        <mxCell id="L1" value="① 指标定义 · SLI / SLO / 错误预算" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;strokeWidth=2;fontColor=#1e293b;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="58" width="600" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="L1a" value="可用性 · 延迟 · 业务异常 · 资源水位&#xa;触发条件绑在错误预算消耗速率（> 3x 均值）" style="text;html=1;align=center;fontSize=12;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="300" y="86" width="560" height="40" as="geometry"/>
        </mxCell>

        <!-- 第二层：监控采集 -->
        <mxCell id="L2" value="② 监控采集 · 让 AI 能看到系统" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;strokeWidth=2;fontColor=#1e293b;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="166" width="600" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="L2a" value="结构化日志（JSON + RequestId 全链路）&#xa;Prometheus 指标 + CLI 查询接口（供 AI 消费）" style="text;html=1;align=center;fontSize=12;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="300" y="194" width="560" height="40" as="geometry"/>
        </mxCell>

        <!-- 第三层：告警 + AI 调度 -->
        <mxCell id="L3" value="③ 告警 + AI 调度 · 从通知人到触发 AI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;strokeWidth=2;fontColor=#1e293b;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="274" width="600" height="98" as="geometry"/>
        </mxCell>
        <mxCell id="L3a" value="告警 webhook → 去重 → 环境/代码分流&#xa;AI 调度器：捞日志、捞指标、bot 拉代码、LLM 诊断&#xa;三路分流：可自动修 / 风险高 / 不可修" style="text;html=1;align=center;fontSize=12;fontColor=#1e293b;" vertex="1" parent="1">
          <mxGeometry x="300" y="302" width="560" height="60" as="geometry"/>
        </mxCell>

        <!-- 第四层：修复验证 -->
        <mxCell id="L4" value="④ 自动修复 + 验证 · 从改代码到提 PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;strokeWidth=2;fontColor=#1e293b;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="402" width="600" height="98" as="geometry"/>
        </mxCell>
        <mxCell id="L4a" value="创建 fix 分支 → 修代码 → commit&#xa;三层验证：静态检查 → 全量测试 → AI 自我 review&#xa;全过 → 提 PR 到 dev（不自动合并，等人 review）" style="text;html=1;align=center;fontSize=12;fontColor=#1e293b;" vertex="1" parent="1">
          <mxGeometry x="300" y="430" width="560" height="60" as="geometry"/>
        </mxCell>

        <!-- 第五层：通知记录 -->
        <mxCell id="L5" value="⑤ 通知 + 记录 + Changelog · 让人知道机器做了什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;strokeWidth=2;fontColor=#1e293b;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="530" width="600" height="98" as="geometry"/>
        </mxCell>
        <mxCell id="L5a" value="飞书 / 邮件通知（按紧急度分流）&#xa;结构化修复记录 → 监控面板（成功率、MTTR、分布）&#xa;Changelog 自动追加，按月汇总进版本发布说明" style="text;html=1;align=center;fontSize=12;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="300" y="558" width="560" height="60" as="geometry"/>
        </mxCell>

        <!-- 层间箭头 -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="L1" target="L2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="L2" target="L3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="L3" target="L4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e45" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="L4" target="L5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 反馈闭环：第五层 → 第一层 -->
        <mxCell id="feedback" value="运营数据回流&#xa;成功率 / MTTR / 分布&#xa;→ 新的监控指标" style="text;html=1;align=center;fontSize=11;fontColor=#2563eb;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="920" y="320" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_fb" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2563eb;strokeWidth=1.5;endArrow=classic;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="L5" target="L1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1000" y="579"/>
              <mxPoint x="1000" y="97"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 左侧标注：传统监控止于此 -->
        <mxCell id="legacy" value="传统监控止于此&#xa;（告警 → 等人处理）" style="text;html=1;align=right;fontSize=11;fontColor=#94a3b8;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_legacy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#94a3b8;strokeWidth=1;dashed=1;endArrow=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="legacy" target="L3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 底部注释 -->
        <mxCell id="note" value="闭环核心：① → ⑤ → ①。自愈体系的运营数据本身就是新的监控指标，需要被度量。" style="text;html=1;align=center;fontSize=12;fontColor=#64748b;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="660" width="760" height="24" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
