        </mxCell>
        <mxCell id="N_P1" value="P1 高可用（稳基）&#xa;—&#xa;• MySQL / Redis 主从&#xa;• 多实例 + 健康检查&#xa;• 基础监控与日志" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="184" width="420" height="124" as="geometry"/>
        </mxCell>
        <mxCell id="N_P2" value="P2 高并发（扛量）&#xa;—&#xa;• 读写分离&#xa;• 公开页缓存与限流 / 熔断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="352" width="420" height="108" as="geometry"/>
        </mxCell>
        <mxCell id="N_P3" value="P3 体验与成本（优化）&#xa;—&#xa;• CDN / 缓存&#xa;• 异步任务&#xa;• 多运行时 / 多地域（可选）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="504" width="420" height="124" as="geometry"/>
        </mxCell>
        <mxCell id="N_P4" value="P4 平台化（演进）&#xa;—&#xa;• 多租户与配额&#xa;• 开放 API / Webhook&#xa;• 审计与版本 / 回滚" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
