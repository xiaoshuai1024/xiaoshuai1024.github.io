<mxfile host="app.diagrams.net">
  <diagram name="演进路线" id="luban-roadmap">
    <mxGraphModel dx="820" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="820" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="N_P0" value="P0 功能闭环&#xa;—&#xa;• 六库打通&#xa;• API 契约统一" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
