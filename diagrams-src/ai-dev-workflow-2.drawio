<mxfile host="app.diagrams.net">
  <diagram name="串行 vs 并行 subagent" id="parallel">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="同一个问题,串行问 AI 和并行扇出去的本质区别" style="text;html=1;align=center;fontColor=#1e293b;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="700" height="30" as="geometry"/>
        </mxCell>

        <!-- 左侧:串行 -->
        <mxCell id="ser_title" value="串行问 AI(把 AI 当搜索引擎)" style="text;html=1;align=center;fontColor=#64748b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="320" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="ser_user" value="人" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="220" y="110" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ser_ai1" value="AI 回答 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="180" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ser_ai2" value="AI 回答 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="250" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ser_ai3" value="AI 回答 3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="320" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ser_out" value="单条结论" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="390" width="100" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="se1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;endArrow=block;fontSize=10;" edge="1" parent="1" source="ser_user" target="ser_ai1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="se2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;endArrow=block;fontSize=10;" edge="1" parent="1" source="ser_ai1" target="ser_ai2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="se3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;endArrow=block;fontSize=10;" edge="1" parent="1" source="ser_ai2" target="ser_ai3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="se4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;endArrow=block;fontSize=10;" edge="1" parent="1" source="ser_ai3" target="ser_out"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="ser_note" value="特征:&#10;• 单线来回,认知窄&#10;• 后一次只在前一次的影子里&#10;• 容易被第一回答带偏&#10;• 慢" style="text;html=1;align=left;fontColor=#64748b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="180" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- 右侧:并行 -->
        <mxCell id="par_title" value="并行扇出去(把 AI 当一支团队)" style="text;html=1;align=center;fontColor=#0f766e;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="320" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="par_user" value="人" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0f766e;fontColor=#1e293b;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="760" y="110" width="60" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="par_a1" value="agent A&#10;视角:架构" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#0f766e;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="190" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="par_a2" value="agent B&#10;视角:性能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#0f766e;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="740" y="190" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="par_a3" value="agent C&#10;视角:边界 / 异常" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#0f766e;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="190" width="110" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="par_merge" value="汇总 / 取舍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0f766e;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="290" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="par_out" value="多维结论&#10;(更稳)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0f766e;fontColor=#1e293b;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="370" width="100" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="pe1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;endArrow=block;fontSize=10;" edge="1" parent="1" source="par_user" target="par_a1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="670" y="170"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="pe2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;endArrow=block;fontSize=10;" edge="1" parent="1" source="par_user" target="par_a2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="790" y="170"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="pe3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;endArrow=block;fontSize=10;" edge="1" parent="1" source="par_user" target="par_a3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="915" y="170"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="pe4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;endArrow=block;fontSize=10;" edge="1" parent="1" source="par_a1" target="par_merge"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pe5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;endArrow=block;fontSize=10;" edge="1" parent="1" source="par_a2" target="par_merge"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pe6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;endArrow=block;fontSize=10;" edge="1" parent="1" source="par_a3" target="par_merge"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pe7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f766e;endArrow=block;fontSize=10;" edge="1" parent="1" source="par_merge" target="par_out"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="par_note" value="特征:&#10;• 多视角同时探索&#10;• 互不知道,各自独立&#10;• 汇总时人做取舍&#10;• 快,且结论更鲁棒" style="text;html=1;align=left;fontColor=#64748b;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="380" width="200" height="100" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
