        <mxCell id="PM" value="PM 的起点&#xa;&#xa;「为什么做、给谁做」&#xa;&#xa;用户 · 价值 · 指标&#xa;场景 · 范围 · 验证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;strokeWidth=2;fontColor=#1e293b;fontSize=13;align=center;" vertex="1" parent="1">
          <mxGeometry x="650" y="110" width="280" height="200" as="geometry"/>
