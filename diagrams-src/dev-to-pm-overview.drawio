        <mxCell id="GAP" value="AI 削平了&#xa;这道坎" style="text;html=1;align=center;fontSize=12;fontColor=#2563eb;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="420" y="160" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="BRIDGE" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;startArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="DEV" target="PM">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ESSENCE" value="本质:价值判断从「拍脑袋」变成「走流程」&#xa;命令系统逼研发把产品逻辑想透" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;strokeWidth=2;fontColor=#1e293b;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="390" width="480" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="DOWN" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#94a3b8;dashed=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="490" y="320" as="sourcePoint"/>
            <mxPoint x="490" y="390" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="NOTE1" value="执行层&#xa;AI 接管" style="text;html=1;align=center;fontSize=11;fontColor=#64748b;" vertex="1" parent="1">
          <mxGeometry x="70" y="370" width="100" height="40" as="geometry"/>
