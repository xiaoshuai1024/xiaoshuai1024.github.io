        </mxCell>
        <mxCell id="E" value="终端用户" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdfa;strokeColor=#5eead4;fontColor=#134e4a;fontSize=12;fontStyle=1;" vertex="1" parent="1">
