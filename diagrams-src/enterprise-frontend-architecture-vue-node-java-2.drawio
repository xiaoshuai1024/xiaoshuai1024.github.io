<mxfile host="app.diagrams.net">
  <diagram name="阶段1单体架构" id="stage1">
    <mxGraphModel dx="900" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
