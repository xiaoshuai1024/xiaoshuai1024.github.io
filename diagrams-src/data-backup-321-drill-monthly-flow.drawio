<mxfile host="app.diagrams.net">
  <diagram name="月度恢复演练" id="monthly-drill">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="420" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="s1" value="① 隔离环境&#10;建空 MySQL&#10;&#10;绝不复用现网&#10;不污染生产" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="160" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="② 全量 dump 恢复&#10;&#10;mysql &lt; dump.sql.gz&#10;验证快照没损坏" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="230" y="80" width="160" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="③ binlog PITR 接力&#10;&#10;mysqlbinlog 按位点&#10;恢复到故障前最后一刻&#10;（最易出错的一步）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="80" width="160" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="④ 关键表对账&#10;&#10;SELECT COUNT(*)&#10;FROM users/orders/...&#10;验证与现网一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="630" y="80" width="160" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="s5" value="⑤ 报告归档&#10;+ 门禁判定&#10;&#10;失败 → 阻断发布" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="80" width="160" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#64748b;fontSize=11;" edge="1" parent="1" source="s4" target="s5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="rto" value="报告量化真实 RTO：从拉 dump 到对账通过的总耗时 → 校验「1 小时 RTO」承诺靠不靠谱" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="230" y="240" width="660" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="core" value="演练的价值不在「跑通」，在「暴露 PITR 接力/位点漂移/对账偏差」—— 这些只有真跑才暴露，真灾难来时才不会手忙脚乱" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="300" width="820" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="er" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#94a3b8;fontSize=11;dashed=1;" edge="1" parent="1" source="s5" target="rto">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
