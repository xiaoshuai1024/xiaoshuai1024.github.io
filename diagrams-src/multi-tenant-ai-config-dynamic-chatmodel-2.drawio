        <mxCell id="R5" value="构建并缓存" style="endArrow=open;html=1;strokeColor=#14b8a6;dashed=1;fontSize=10;fontColor=#134e4a;" edge="1" parent="1" source="FAC" target="OPENAI">
          <mxGeometry relative="1" as="geometry"/>
