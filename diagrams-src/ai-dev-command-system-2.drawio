<mxfile host="app.diagrams.net">
  <diagram name="kd-review 收敛机制" id="kdreview">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="TITLE" value="/kd-review:审查的本质是收敛问题。串行是慢的根因,所以全程 streaming 并行,直到连续 3 轮零任何问题才停" style="text;html=1;align=center;fontColor=#1e293b;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="S1" value="① 并行审查&#10;21 个窄范围 bucket 同时启动&#10;每个 agent 只审 1-5 个文件,独立 worktree" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2563eb;strokeColor=#2563eb;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="S2" value="② Streaming 修复&#10;结果到达即派修复 agent&#10;不等待全部审查完成,🔴 阻断直接修" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2563eb;strokeColor=#2563eb;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="S3" value="③ 收敛循环&#10;clean_continuous ≥ 3 才退出&#10;至少 1 轮全量审查,每 5 轮强制全量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2563eb;strokeColor=#2563eb;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="280" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="S4" value="✅ 自动提交 + 推送&#10;测试门禁全绿后" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="80" width="190" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="FL1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="S1" target="S2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="FL2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="S2" target="S3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="FL3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="S3" target="S4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="LOOP" value="未收敛 → 回到①,只重审上一轮出问题的 bucket(增量)" style="text;html=1;align=center;fontColor=#dc2626;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="175" width="700" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="SECT" value="关键设计:墙钟时间 = max(所有审查) + max(所有修复),不是 sum" style="text;html=1;align=left;fontColor=#0f766e;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="700" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="TG_TITLE" value="提交前硬门禁:编译 → 单测+覆盖率 → API 契约检查 → E2E,任一失败自动派修复循环(最多 3 轮),全绿才提交" style="text;html=1;align=center;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="1200" height="26" as="geometry"/>
        </mxCell>

        <mxCell id="TG1" value="编译验证&#10;mvn compile / pnpm build" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="285" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="TG2" value="单测 + 覆盖率门禁&#10;行 95% / 分支 85%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="260" y="285" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="TG3" value="API 契约检查&#10;前端调用 vs 后端 @*Mapping" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="285" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="TG4" value="P0 E2E 最终确认&#10;交易 + 运营后台" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontColor=#1e293b;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="285" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="TG5" value="E2E 环境不可用&#10;禁止 skip / 禁止占位测试&#10;标 🔴 不提交" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontColor=#dc2626;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="285" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="TGE1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#64748b;" edge="1" parent="1" source="TG1" target="TG2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="TGE2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#64748b;" edge="1" parent="1" source="TG2" target="TG3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="TGE3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#64748b;" edge="1" parent="1" source="TG3" target="TG4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="TGE4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#dc2626;dashed=1;" edge="1" parent="1" source="TG4" target="TG5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="DATA_TITLE" value="实战收敛时间线(联合套卡模块审查,11 轮收敛)" style="text;html=1;align=center;fontColor=#1e293b;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="1200" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="TH" value="轮次 | 策略 | 审查 | 修复 | 🔴 | 🟡 | 连续零问题&#10;R1 | 全量并行 | 21 | 13 | 38 | 110 | 0&#10;R2 | streaming 修复 | 8 | 8 | 14 | 12 | 0&#10;R3 | 增量重审 | 5 | 3 | 1 | 3 | 0&#10;R4 | 修复残留 | — | 3 | 0 | 0 | 1&#10;R5 | 快速扫描 | 3 | 1 | 0 | 0 | 2&#10;R6 | 横切再审 | 2 | 2 | 1 | 0 | 0&#10;R7-R11 | 递增验证 | 1 | — | 0 | 0 | 1→5" style="text;html=1;align=center;fontColor=#1e293b;fontSize=11;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="340" y="390" width="600" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="NOTE1" value="前 3 轮(全量审查 + 修复 + 验证)是核心价值所在 —— 38 个 🔴 + 110 个 🟡 全在 R1-R3 消化" style="text;html=1;align=center;fontColor=#0f766e;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="1200" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="NOTE2" value="R7+ 用 grep 直接验证代替启动 agent,wall-clock 显著缩短 —— 收敛后期不需要重型 agent" style="text;html=1;align=center;fontColor=#0f766e;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="584" width="1200" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="NOTE3" value="一次事故催生的设计:删掉的并发保护代码、调用不存在端点的前端代码,编译过但测试没跑 —— 所以测试门禁是硬前置" style="text;html=1;align=center;fontColor=#dc2626;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="608" width="1200" height="22" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
